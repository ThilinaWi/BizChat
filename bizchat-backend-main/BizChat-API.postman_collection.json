              "name": "Delete Ticket",
              "request": {
                "method": "DELETE",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "tickets", "{{ticketId}}"]
                },
                "description": "Delete a ticket tier. Manager/Admin only."
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "User",
          "item": [
            {
              "name": "Create Booking",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "    const json = pm.response.json();",
                      "    if (json.data && json.data._id) pm.collectionVariables.set('bookingId', json.data._id);",
                      "    if (json.data && json.data.bookingReference) pm.collectionVariables.set('bookingReference', json.data.bookingReference);",
                      "}"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"ticketId\": \"{{ticketId}}\",\n  \"quantity\": 2,\n  \"attendees\": [\n    {\n      \"firstName\": \"John\",\n      \"lastName\": \"Doe\",\n      \"email\": \"john.doe@example.com\",\n      \"phoneNumber\": \"+94771234567\"\n    },\n    {\n      \"firstName\": \"Jane\",\n      \"lastName\": \"Doe\",\n      \"email\": \"jane.doe@example.com\",\n      \"phoneNumber\": \"+94777654321\"\n    }\n  ]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/bookings",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "bookings"]
                },
                "description": "Create a booking. `quantity` must match the number of attendee objects (max 10). Payment is handled at the venue; booking starts as PENDING/UNPAID.\n\nAuto-saves `bookingId` and `bookingReference`."
              }
            },
            {
              "name": "Get My Bookings",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/bookings/my?page=1&limit=10",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "bookings", "my"],
                  "query": [
                    { "key": "page",  "value": "1"  },
                    { "key": "limit", "value": "10" }
                  ]
                },
                "description": "Returns the authenticated user's bookings, paginated."
              }
            },
            {
              "name": "Get Booking by ID",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/bookings/{{bookingId}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "bookings", "{{bookingId}}"]
                },
                "description": "Get a single booking. Users can only view their own; managers/admins can view any."
              }
            },
            {
              "name": "Cancel Booking",
              "request": {
                "method": "POST",
                "header": [],
                "body": { "mode": "raw", "raw": "" },
                "url": {
                  "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "bookings", "{{bookingId}}", "cancel"]
                },
                "description": "Cancel a pending booking. Cannot cancel a CONFIRMED booking. Restores ticket quantity."
              }
            }
          ]
        },
        {
          "name": "Manager / Admin",
          "item": [
            {
              "name": "Verify Booking (Mark Paid)",
              "request": {
                "method": "POST",
                "header": [],
                "body": { "mode": "raw", "raw": "" },
                "url": {
                  "raw": "{{baseUrl}}/api/bookings/{{bookingId}}/verify",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "bookings", "{{bookingId}}", "verify"]
                },
                "description": "Mark a booking as PAID and CONFIRMED after receiving payment at the venue. Triggers a ticket confirmation email to attendees. Manager/Admin only."
              }
            },
            {
              "name": "Get Booking by Reference",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/bookings/reference/{{bookingReference}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "bookings", "reference", "{{bookingReference}}"]
                },
                "description": "Look up a booking by its human-readable reference (format: `BK-XXXXXXXX`). Manager/Admin only."
              }
            },
            {
              "name": "Get All Bookings",
              "request": {
                "method": "GET",
                "header": [],
