                  "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"name\": \"General Admission\",\n  \"description\": \"Standard entry ticket\",\n  \"price\": 2500,\n  \"totalQuantity\": 200\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/tickets",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "tickets"]
                },
                "description": "Create a ticket tier for an event. `price` is in LKR cents or your currency unit. Manager/Admin only.\n\nAuto-saves `ticketId`."
